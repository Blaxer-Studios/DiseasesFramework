<?xml version="1.0" encoding="utf-8" ?>
<Patch>

    <!-- Body part item patch -->
    <!-- Injects the contamination component into harvested body parts and implants -->
    <!-- Targets natural, bionic, royal, and imperial prosthetic bases -->
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[@ParentName="BodyPartProstheticImperialBase" or @ParentName="BodyPartBionicImperialBase" or @ParentName="BodyPartRoyalBase" or @ParentName="BodyPartNaturalBase"]</xpath>
        <value>
            <comps>
                <li Class="DiseasesFramework.InfectionVectors.DF_Surgery.CompProperties_ContaminatedBodyPart"/>
            </comps>
        </value>
    </Operation>

</Patch>